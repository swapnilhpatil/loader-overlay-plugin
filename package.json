  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "loader",
    "overlay",
    "spinner",
    "loading",
    "progress",
    "component",
    "library"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.2.0"
  }
}